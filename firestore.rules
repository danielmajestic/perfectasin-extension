rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users — owner read/write only
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Subscriptions — owner read only (writes from backend/Stripe webhook)
    match /subscriptions/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // server-side only
    }

    // Usage — owner read only (writes from backend via admin SDK)
    // Doc ID format: {uid}_{YYYY-MM} — uid prefix must match authenticated user
    match /usage/{docId} {
      allow read: if request.auth != null
        && (resource == null || resource.data.uid == request.auth.uid)
        && docId.matches(request.auth.uid + '_.*');
      allow write: if false; // server-side only
    }

    // Analyses — owner read only (writes from backend)
    match /analyses/{docId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow write: if false; // server-side only
    }

    // Waitlist — create only, no auth required
    match /waitlist/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
